# ==========================================
# KONFIGURASI DATABASE (Neon PostgreSQL)
# Dapatkan dari: https://neon.tech/
# ==========================================
DATABASE_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ==========================================
# KONFIGURASI NEXTAUTH
# NEXTAUTH_SECRET: generate dengan: openssl rand -base64 32
# NEXTAUTH_URL: URL aplikasi (ubah saat deploy)
# ==========================================
NEXTAUTH_SECRET="ganti_dengan_random_string_32_karakter"
NEXTAUTH_URL="http://localhost:3000"

# ==========================================
# KONFIGURASI DOMAIN SEKOLAH
# Sesuaikan dengan domain email sekolah Anda
# ==========================================
NEXT_PUBLIC_SCHOOL_NAME="SMAN 1 Contoh"
NEXT_PUBLIC_SCHOOL_SHORT="SK"
NEXT_PUBLIC_STUDENT_DOMAIN="siswa.sman1contoh.sch.id"
NEXT_PUBLIC_STAFF_DOMAIN="sman1contoh.sch.id"

# ==========================================
# KONFIGURASI POIN KRITIS SISWA
# ==========================================
NEXT_PUBLIC_CRITICAL_POINTS=75
NEXT_PUBLIC_WARNING_POINTS=50

# Password awal untuk siswa baru (tambah satuan / impor bulk), bila tidak diisi di form
# DEFAULT_STUDENT_PASSWORD="Siswa@1234"
